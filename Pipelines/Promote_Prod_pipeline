pipeline {
    agent {
        kubernetes {
            yaml """
            apiVersion: v1
            kind: Pod
            metadata:
              labels:
                purpose: jenkins-git-pod
            spec:
              containers:
              - name: git
                image: ubuntu:latest
                command:
                - bash
                - -c
                - |
                  apt-get update && apt-get install -y git curl
                  exec bash
                tty: true
                volumeMounts:
                - name: workspace-volume
                  mountPath: /home/jenkins/agent
              - name: jnlp
                image: jenkins/inbound-agent:3261.v9c670a_4748a_9-1
                volumeMounts:
                - name: workspace-volume
                  mountPath: /home/jenkins/agent
              volumes:
              - name: workspace-volume
                emptyDir: {}
            """
        }
    }
    environment {
        GIT_USER_NAME = 'nour20-maker'
        GIT_USER_EMAIL = 'nourelhouda.zraibia@esprit.tn'
        GIT_CREDENTIALS_ID = 'github'
        GITHUB_TOKEN = credentials('github')
        
        
        K8S_YAML_PATH1 = 'Prod/backend-deployment.yaml'
        K8S_YAML_PATH2 = 'Prod/frontend-deployment.yaml'
    }
    stages {
        stage('Install Git and Curl') {
            steps {
                container('git') {
                    sh """
                    apt-get update && apt-get install -y git curl
                    """
                }
            }
        }
        stage('Checkout Repository') {
            steps {
                container('git') {
                    script {
                        withCredentials([usernamePassword(credentialsId: "${GIT_CREDENTIALS_ID}", usernameVariable: 'GIT_USERNAME', passwordVariable: 'GIT_PASSWORD')]) {
                            sh """
                            git config --global user.name "${GIT_USER_NAME}"
                            git config --global user.email "${GIT_USER_EMAIL}"
                            
                            git clone https://\$GIT_USERNAME:\$GIT_PASSWORD@github.com/nour10-maker/dev_team_khedmasite.git /home/jenkins/agent/khedmadeploy
                            git clone https://\$GIT_USERNAME:\$GIT_PASSWORD@github.com/nour20-maker/DeploymentFilesKhedmaSite.git /home/jenkins/agent/kubefiles
                            """
                        }
                    }
                }
            }
        }
        stage('Create Release') {
            steps {
                container('git') {
                    script {
                        dir('/home/jenkins/agent/khedmadeploy') {
                            def newTag = sh(returnStdout: true, script: "git rev-parse --short HEAD").trim()
                            env.TAG = newTag
                            sh """
                            git tag -a ${env.TAG} -m "Release for commit ${env.TAG}"
                            git push --tags
                            """
                        }
                    }
                }
            }
        }
        stage('Update Kubernetes YAML') {
            steps {
                container('git') {
                    script {
                        dir('/home/jenkins/agent/kubefiles') {
                            sh """
                            sed -i 's|image: .*|image: lou4y/backend:${env.TAG}|' ${K8S_YAML_PATH1}
                            sed -i 's|image: .*|image: lou4y/frontend:${env.TAG}|' ${K8S_YAML_PATH2}
                            git add .
                            git commit -m "Update image tag to ${env.TAG}" || echo "No changes to commit"
                            git push
                            """
                        }
                    }
                }
            }
        }
    }
}
